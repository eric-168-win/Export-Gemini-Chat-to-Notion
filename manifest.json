{
    "manifest_version": 3,
    "name": "Gemini to Notion Exporter",
    "version": "1.0",
    "description": "Export Gemini chats to Notion Database.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://api.notion.com/*",
        "https://gemini.google.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://gemini.google.com/*"
            ],
            "js": [
                "turndown.js",
                "content.js"
            ]
        }
    ]
}